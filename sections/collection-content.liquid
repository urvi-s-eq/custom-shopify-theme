{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}
<section class="cwr-collections">
        <div class="container">
            <div class="cwr-form">
                {% for block in section.blocks %}
                <div class="cwr-collections__nav">
                    <div class="cwr-collections__nav-title">
                        <h5 class="cwr-title cwr-title--style-5">
                            {{ block.settings.custom_title | default: "Categories:" }}
                        </h5>
                    </div>
                    {% assign custom_menu = linklists[block.settings.custom_menu] %}
                    <ul class="cwr-collections__nav-list">
                        {% for link in custom_menu.links %}
                        <li> 
                            <a class="cwr-collections__nav-link{% if forloop.first %} active {% endif %}" href="{{ link.url }}">
                            {{ link.title }}
                            </a>
                        </li>
                        {% endfor %}
                    </ul>
                </div>
                {% endfor %}
                <div class="row">
                    {{ 'component-facets.css' | asset_url | stylesheet_tag }}
                    <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
                    <div class="cwr-collections__col cwr-collections__col--filter">
                      {% if section.settings.enable_filtering or section.settings.enable_sorting %}
                        <form id="cwr-filter-form" method="get" action="{{ collection.url }}">
                          <div class="cwr-collections__filter">
                            <div class="cwr-collections__filte-title">
                              <h6 class="cwr-title cwr-title--style-6">{{ 'products.facets.filter_by_label' | t }}</h6>
                              <a type="button" class="cwr-collections__filter-clear-btn js-clear-all">{{ 'products.facets.clear_all' | t }}</a>
                            </div>
                            <div class="cwr-faq-main js-faq-main-wrapper">
                                {% if collection.filters.size > 0 %}
                                    <ul>
                                      {% for filter in collection.filters %}
                                        {% if filter.label == "Select color" %}
                                          <li class="cwr-faq-main__item">
                                            <div class="cwr-faq-main__que cwr-faq-main__que--coll-filter js-faq-main-que">
                                              <h6 class="cwr-title cwr-title--style-6">{{ filter.label }}</h6>
                                              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                                                <path d="M3.6 12.375L8.99998 6.375L14.4 12.375" stroke="black" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                                              </svg>
                                            </div>
                                            <div class="cwr-faq-main__ans cwr-faq-main__ans--coll-filter js-faq-main-ans" style="display: none;">
                                              <fieldset class="cwr-form__fieldset cwr-form__fieldset--color-variant">
                                                {% for value in filter.values %}
                                                  {% assign color_parts = value.label | split: ':' %}
                                                  {% assign hex = color_parts[0] | strip %}
                                                  {% assign name = color_parts[1] | default: value.label | strip %}
                                                  <div class="cwr-form__field cwr-form__field--color-variant">
                                                    <input type="checkbox"
                                                          class="cwr-form__input cwr-form__input--color-variant"
                                                          name="{{ filter.param_name }}"
                                                          id="color-variant-{{ forloop.index }}"
                                                          value="{{ value.value }}"
                                                          {% if value.active %}checked{% endif %}
                                                          {% if value.count == 0 and value.active == false %}disabled{% endif %}>
                                                    <label style="background-color: {{ hex }}; outline-color: {{ hex }};"
                                                          for="color-variant-{{ forloop.index }}"
                                                          class="cwr-form__label cwr-form__label--color-variant">{{ name }}</label>
                                                  </div>
                                                {% endfor %}
                                              </fieldset>
                                            </div>
                                          </li>
                                          {% elsif filter.label == "More filters" %}
                                            {% assign brands = '' %}
                                            {% assign categories = '' %}
                                            {% for value in filter.values %}
                                              {% assign prefix = value.label | split: ':' | first | strip %}
                                              {% assign label = value.label %}
                                              {% assign val = value.value %}
                                              {% if prefix == "Brands" %}
                                                {% capture brands %}
                                                  {{ brands }}
                                                  <div class="cwr-form__field cwr-form__field--check">
                                                    <input type="checkbox"
                                                          class="cwr-form__input cwr-form__input--check"
                                                          name="{{ filter.param_name }}"
                                                          id="brand-{{ forloop.index }}"
                                                          value="{{ val }}"
                                                          {% if value.active %}checked{% endif %}
                                                          {% if value.count == 0 and value.active == false %}disabled{% endif %}>
                                                    <label for="brand-{{ forloop.index }}" class="cwr-form__label cwr-form__label--check">{{ label | remove: 'Brands :' | strip }}</label>
                                                  </div>
                                                {% endcapture %}
                                              {% elsif prefix == "Category" %}
                                                {% capture categories %}
                                                  {{ categories }}
                                                  <div class="cwr-form__field cwr-form__field--check">
                                                    <input type="checkbox"
                                                          class="cwr-form__input cwr-form__input--check"
                                                          name="{{ filter.param_name }}"
                                                          id="category-{{ forloop.index }}"
                                                          value="{{ val }}"
                                                          {% if value.active %}checked{% endif %}
                                                          {% if value.count == 0 and value.active == false %}disabled{% endif %}>
                                                    <label for="category-{{ forloop.index }}" class="cwr-form__label cwr-form__label--check">{{ label | remove: 'Category :' | strip }}</label>
                                                  </div>
                                                {% endcapture %}
                                              {% endif %}
                                            {% endfor %}
                                            {% if brands != blank %}
                                              <li class="cwr-faq-main__item">
                                                <div class="cwr-faq-main__que cwr-faq-main__que--coll-filter js-faq-main-que">
                                                  <h6 class="cwr-title cwr-title--style-6">Select Brand</h6>
                                                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                                                    <path d="M3.6 12.375L8.99998 6.375L14.4 12.375" stroke="black" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                                                  </svg>
                                                </div>
                                                <div class="cwr-faq-main__ans cwr-faq-main__ans--coll-filter js-faq-main-ans" style="display: none;">
                                                  <fieldset>{{ brands }}</fieldset>
                                                </div>
                                              </li>
                                            {% endif %}
                                            {% if categories != blank %}
                                              <li class="cwr-faq-main__item">
                                                <div class="cwr-faq-main__que cwr-faq-main__que--coll-filter js-faq-main-que">
                                                  <h6 class="cwr-title cwr-title--style-6">Select Category</h6>
                                                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                                                    <path d="M3.6 12.375L8.99998 6.375L14.4 12.375" stroke="black" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                                                  </svg>
                                                </div>
                                                <div class="cwr-faq-main__ans cwr-faq-main__ans--coll-filter js-faq-main-ans" style="display: none;">
                                                  <fieldset>{{ categories }} </fieldset>
                                                </div>
                                              </li>
                                            {% endif %}
                                            {% elsif filter.type == 'price_range' %}
                                              {% assign min = filter.min_value.value %}
                                              {% assign max = filter.max_value.value %}
                                              <li class="cwr-faq-main__item">
                                                <div class="cwr-faq-main__que cwr-faq-main__que--coll-filter js-faq-main-que">
                                                  <h6 class="cwr-title cwr-title--style-6">Price</h6>
                                                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                                                    <path d="M3.6 12.375L8.99998 6.375L14.4 12.375" stroke="black" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                                                  </svg>
                                                </div>
                                                <div class="cwr-faq-main__ans cwr-faq-main__ans--coll-filter js-faq-main-ans" style="display: none;">
                                                  <div class="cwr-range-slider">
                                                    <facet-filters-form>
                                                      <form class="facets-price-form" id="PriceRangeForm">
                                                        <div class="cwr-range-slider__inputs" style="display: flex; align-items: center; gap: 10px;">
                                                          <label for="price-min" class="cwr-label" style="white-space: nowrap;">Min</label>
                                                          <input
                                                              type="number"
                                                              name="filter.v.price.gte"
                                                              id="price-min"
                                                              value="{{ min | divided_by: 100.0 | default: '' }}"
                                                              min="{{ filter.range_min | divided_by: 100.0 }}"
                                                              max="{{ filter.range_max | divided_by: 100.0 }}"
                                                              placeholder="{{ filter.range_min | divided_by: 100.0 }}"
                                                              class="cwr-input price-input"
                                                              style="max-width: 60px;"
                                                            >
                                                          <span class="cwr-range-slider__dash">-</span>
                                                          <label for="price-max" class="cwr-label" style="white-space: nowrap;">Max</label>
                                                          <input
                                                          type="number"
                                                          name="filter.v.price.lte"
                                                          id="price-max"
                                                          value="{{ max | divided_by: 100.0 | default: '' }}"
                                                          min="{{ filter.range_min | divided_by: 100.0 }}"
                                                          max="{{ filter.range_max | divided_by: 100.0 }}"
                                                          placeholder="{{ filter.range_max | divided_by: 100.0 }}"
                                                          class="cwr-input price-input"
                                                          style="max-width: 60px;"
                                                        >
                                                        </div>
                                                      </form>
                                                    </facet-filters-form>
                                                  </div>
                                                </div>
                                              </li>
                                        {% else %}
                                          <li class="cwr-faq-main__item">
                                            <div class="cwr-faq-main__que cwr-faq-main__que--coll-filter js-faq-main-que">
                                              <h6 class="cwr-title cwr-title--style-6">{{ filter.label }}</h6>
                                              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                                                <path d="M3.6 12.375L8.99998 6.375L14.4 12.375" stroke="black" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                                              </svg>
                                            </div>
                                            <div class="cwr-faq-main__ans cwr-faq-main__ans--coll-filter js-faq-main-ans" style="display: none;">
                                              <fieldset class="cwr-form__fieldset">
                                                {% for value in filter.values %}
                                                    <div class="cwr-form__field cwr-form__field--check">
                                                        <input type="checkbox"
                                                              class="cwr-form__input cwr-form__input--check"
                                                              name="{{ filter.param_name }}"
                                                              id="{{ filter.param_name }}-{{ forloop.index }}"
                                                              value="{{ value.value }}"
                                                              {% if value.active %}checked{% endif %}
                                                              {% if value.count == 0 and value.active == false %}disabled{% endif %}>
                                                        <label for="{{ filter.param_name }}-{{ forloop.index }}" class="cwr-form__label cwr-form__label--check">
                                                          {{ value.label }}
                                                        </label>
                                                      </div>
                                                {% endfor %}
                                              </fieldset>
                                            </div>
                                          </li>
                                        {% endif %}
                                      {% endfor %}
                                    </ul>
                                  {% endif %}  
                            </div>
                          </div>
                        </form>
                      {% endif %}
                      <div class="cwr-collections__secure">
                        <div class="cwr-collections__secure-content">
                            <span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                                    <g clip-path="url(#clip0_48_1913)">
                                      <path d="M2.89392 7.52049C3.57402 7.36848 4.39133 7.21481 5.30965 7.09732V5.59358C5.30965 3.84164 6.73495 2.41633 8.48689 2.41633C10.2388 2.41633 11.6641 3.84164 11.6641 5.59358V7.09732C12.5825 7.21481 13.3998 7.36848 14.0799 7.52049V5.59358C14.0799 2.50964 11.5709 0.000640869 8.48689 0.000640869C5.40292 0.000640869 2.89392 2.50964 2.89392 5.59361V7.52049Z" fill="black"/>
                                      <path d="M8.4865 11.2284C8.12333 11.2284 7.82788 11.5238 7.82788 11.887C7.82788 12.2502 8.12333 12.5457 8.4865 12.5457C8.84966 12.5457 9.14512 12.2502 9.14512 11.887C9.14515 11.5238 8.84966 11.2284 8.4865 11.2284Z" fill="black"/>
                                      <path d="M8.48639 7.94595C5.17179 7.94595 2.41062 8.69724 1.4646 8.98862V16.9582C2.41206 17.2494 5.17921 18.0012 8.48639 18.0012C11.801 18.0012 14.5622 17.2499 15.5082 16.9585V8.9889C14.5607 8.69773 11.7936 7.94595 8.48639 7.94595ZM9.01374 13.5162V15.2469H7.95905V13.5162C7.27164 13.2932 6.77309 12.647 6.77309 11.8862C6.77309 10.9415 7.54167 10.1729 8.48639 10.1729C9.43111 10.1729 10.1997 10.9415 10.1997 11.8862C10.1997 12.647 9.70118 13.2932 9.01374 13.5162Z" fill="black"/>
                                    </g>
                                    <defs>
                                      <clipPath id="clip0_48_1913">
                                        <rect width="18" height="18" fill="white"/>
                                      </clipPath>
                                    </defs>
                                </svg>
                            </span>
                            <span>{{ section.settings.payment_label }}</span>
                        </div>
                        <div class="cwr-collections__payment-icons">
                            <img width="202" height="16" class="lazyload" src="{{ 'cwr-payment-icons.png' | file_url }}" alt="Payment Icons" />
                        </div>
                      </div>
                    </div>
                    <div class="cwr-collections__col cwr-collections__col--grid">
                        <div class="cwr-collections__right">
                            {%- if section.settings.enable_sorting -%}
                                <facet-filters-form class="facets facets-vertical-sort page-width small-hide">
                                  <form class="facets-vertical-form" method="get" action="{{ collection.url }}" id="FacetSortForm">
                                    <div class="cwr-collections__sorting">
                                      <div class="cwr-form__field cwr-form__field--sort-by">
                                        <label for="sort-by" class="cwr-form__label cwr-form__label--sort-by">
                                          {{ 'products.facets.sort_by_label' | t }}
                                        </label>
                                        <select
                                          class="cwr-form__input cwr-form__input--sort-by"
                                          name="sort_by"
                                          id="sort-by"
                                          aria-describedby="a11y-refresh-page-message"
                                        >
                                          {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
                                          {%- for option in collection.sort_options -%}
                                            <option
                                              value="{{ option.value | escape }}"
                                              {% if option.value == sort_by %}selected{% endif %}
                                            >
                                              {{ option.name | escape }}
                                            </option>
                                          {%- endfor -%}
                                        </select>
                                      </div>
                                    </div>
                                  </form>
                                </facet-filters-form>
                                {% paginate collection.products by section.settings.products_per_row  %}
                                <div class="product-grid-container{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" id="ProductGridContainer" {% if settings.animations_reveal_on_scroll %} data-cascade {% endif %}>
                                  {% if collection.products.size == 0 %}
                                    <div class="collection collection--empty page-width" id="product-grid" data-id="{{ section.id }}">
                                      <div class="loading-overlay gradient"></div>
                                      <div class="title-wrapper center">
                                        <h2 class="title title--primary">
                                          {{ 'sections.collection_template.empty' | t }}
                                          <br>
                                          {{ 'sections.collection_template.use_fewer_filters_html' | t: link: collection.url, class: 'underlined-link link' }}
                                        </h2>
                                      </div>
                                    </div>
                                  {% else %}
                                    <div class="collection">
                                      <div class="loading-overlay gradient"></div>
                                      <div class="row cwr-collections__grid-row grid" id="product-grid" data-id="{{ section.id }}">
                                        {% for product in collection.products %}
                                          {% render 'card-products', product: product %}
                                        {% endfor %}
                                      </div>
                                    </div>
                                  {% endif %}
                                </div>
                                <div id="AjaxinatePagination" class="cwr-collections__cta">
                                  {% if paginate.next %}
                                    <a href="{{ paginate.next.url  }}" class="custom-btn custom-btn--light load-more-button">Load More</a>

                                  {% endif %}
                                </div>
                                {% endpaginate %}
                              {%- endif -%}
                        </div>
                    </div>
                </div>
            </div>
        </div>
</section>
<script>
  let ajaxinateInstance;

  function initAjaxinate() {
    // Always reinit — this is safe since we're replacing the pagination DOM each time
    ajaxinateInstance = new Ajaxinate({
      container: '#product-grid',
      pagination: '#AjaxinatePagination',
      method: 'click',
    });
  }

  document.addEventListener('DOMContentLoaded', function () {
    const productGrid = document.getElementById('product-grid');
    const productGridContainer = document.getElementById('ProductGridContainer');
    const loadingOverlay = productGridContainer.querySelector('.loading-overlay');

    // Sort logic
    const sortForm = document.getElementById('FacetSortForm');
    const sortSelect = sortForm?.querySelector('select[name="sort_by"]');
    if (sortSelect) {
      sortSelect.addEventListener('change', function () {
        const url = new URL(window.location.href);
        url.searchParams.set('sort_by', this.value);

        loadingOverlay.style.display = 'block';

        fetch(url.toString())
          .then(response => response.text())
          .then(html => {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');

            productGrid.innerHTML = doc.getElementById('product-grid')?.innerHTML || '';

            const newPagination = doc.getElementById("AjaxinatePagination");
            const paginationContainer = document.getElementById("AjaxinatePagination");
            if (paginationContainer && newPagination) {
              paginationContainer.innerHTML = newPagination.innerHTML;
            }

            window.history.pushState({}, "", url.toString());
            loadingOverlay.style.display = 'none';

            initAjaxinate(); // Re-init
          })
          .catch(error => {
            console.error('Sort fetch failed:', error);
            loadingOverlay.style.display = 'none';
          });
      });
    }

    // Filter logic
    const filterForm = document.getElementById("cwr-filter-form");
    const clearAllBtn = document.querySelector(".js-clear-all");

    function updateProductsFromForm() {
      const url = new URL(window.location.href);

      for (const param of Array.from(url.searchParams.keys())) {
        if (param.startsWith("filter.") || param === "sort_by") {
          url.searchParams.delete(param);
        }
      }

      const formData = new FormData(filterForm);
      for (const [key, value] of formData.entries()) {
        if (value === "" || value === "0.0") continue;
        if ((key === "filter.v.price.gte" || key === "filter.v.price.lte") &&
          formData.get("filter.v.price.gte") === "0.0" &&
          formData.get("filter.v.price.lte") === "0.0") {
          continue;
        }
        url.searchParams.append(key, value);
      }

      loadingOverlay.style.display = "block";

      fetch(url.toString())
        .then(res => res.text())
        .then(html => {
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, "text/html");

          productGrid.innerHTML = doc.getElementById("product-grid")?.innerHTML || "";

          const newPagination = doc.getElementById("AjaxinatePagination");
          const paginationContainer = document.getElementById("AjaxinatePagination");
          if (paginationContainer && newPagination) {
            paginationContainer.innerHTML = newPagination.innerHTML;
          }

          window.history.pushState({}, "", url.toString());
          loadingOverlay.style.display = "none";

          initAjaxinate(); // Re-init
        })
        .catch(err => {
          console.error("Filter fetch failed:", err);
          loadingOverlay.style.display = "none";
        });
    }

    if (filterForm) {
      filterForm.addEventListener("change", updateProductsFromForm);
    }

    if (clearAllBtn) {
      clearAllBtn.addEventListener("click", function () {
        const inputs = filterForm.querySelectorAll("input, select");
        inputs.forEach(input => {
          if (input.type === "checkbox" || input.type === "radio") {
            input.checked = false;
          } else {
            input.value = "";
          }
        });
        updateProductsFromForm();
      });
    }

    // Price Filter Logic
    const priceForm = document.getElementById('PriceRangeForm');
    if (priceForm) {
      const priceInputs = priceForm.querySelectorAll('.price-input');

      function applyPriceFilter() {
        const formData = new FormData(priceForm);
        const url = new URL(window.location.href);

        url.searchParams.delete('filter.v.price.gte');
        url.searchParams.delete('filter.v.price.lte');

        for (const [key, value] of formData.entries()) {
          if (value) url.searchParams.set(key, value);
        }

        if (loadingOverlay) loadingOverlay.style.display = 'block';

        fetch(url.toString())
          .then(res => res.text())
          .then(html => {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');

            productGrid.innerHTML = doc.getElementById('product-grid')?.innerHTML || '';

            const newPagination = doc.getElementById("AjaxinatePagination");
            const paginationContainer = document.getElementById("AjaxinatePagination");
            if (paginationContainer && newPagination) {
              paginationContainer.innerHTML = newPagination.innerHTML;
            }

            window.history.pushState({}, '', url.toString());
            if (loadingOverlay) loadingOverlay.style.display = 'none';

            initAjaxinate(); // Re-init
          })
          .catch(err => {
            console.error('Price filter fetch failed:', err);
            if (loadingOverlay) loadingOverlay.style.display = 'none';
          });
      }

      priceInputs.forEach(input => {
        input.addEventListener('change', applyPriceFilter);
        input.addEventListener('blur', applyPriceFilter);
      });
    }

    // Initial Ajaxinate setup
    initAjaxinate();
  });
</script>

{% schema %}
  {
      "name": "Collection Content",
      "class": "section",
      "settings": [
          {
          "type": "number",
          "id": "products_per_row",
          "label": "Products Per Row"
          },
          {
          "type": "text",
          "id": "payment_label",
          "label": "Collection Payment Label",
          "default" : "Safe & Secure Checkout"
          },
          {
          "type": "header",
          "content": "t:sections.main-collection-product-grid.settings.header__1.content"
          },
          {
          "type": "checkbox",
          "id": "enable_filtering",
          "default": true,
          "label": "t:sections.main-collection-product-grid.settings.enable_filtering.label",
          "info": "t:sections.main-collection-product-grid.settings.enable_filtering.info"
          },
          {
          "type": "checkbox",
          "id": "enable_sorting",
          "default": true,
          "label": "t:sections.main-collection-product-grid.settings.enable_sorting.label"
          }
      ],
      "blocks": [
          {
              "type": "custom_nav",
              "name": "Custom Nav",
              "settings": [
                  {
                      "type": "text",
                      "id": "custom_title",
                      "label": "Custom Title"
                  },
                  {
                      "type": "link_list",
                      "id": "custom_menu",
                      "label": "Custom Nav"
                  }
              ]
          }
      ],
      "presets" : [
          {
              "name" : "Collection Content"
          }
      ]
  }
{% endschema %}